{
  "name": "hu_eval_2player_groq",
  "description": "2-player HU archetype comparison using Groq llama-3.1-8b-instant. Tests whether a fast, small open-source model follows the bounded options HU widening signals.",
  "hypothesis": "Llama 8B should follow prompt signals well like nano, producing appropriately wide HU VPIP for both archetypes.",
  "tags": ["heads-up-eval", "2player", "groq", "llama", "archetype"],
  "num_tournaments": 10,
  "hands_per_tournament": 50,
  "num_players": 2,
  "starting_stack": 5000,
  "big_blind": 100,
  "model": "llama-3.1-8b-instant",
  "provider": "groq",
  "capture_prompts": true,
  "reset_on_elimination": true,
  "parallel_tournaments": 5,
  "personalities": ["Sun Tzu", "Blackbeard"],
  "player_types": {
    "Sun Tzu": {"type": "hybrid"},
    "Blackbeard": {"type": "hybrid"}
  },
  "control": {
    "label": "hu-tag-vs-lag-groq",
    "enable_psychology": true,
    "prompt_config": {
      "lean_bounded": true,
      "style_aware_options": true,
      "composed_nudges": true,
      "preflop_range_gate": true
    }
  },
  "random_seed": 42
}
