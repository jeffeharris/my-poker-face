# Production secrets - copy to .env.prod and fill in values
# Then encrypt with: age -r YOUR_SERVER_PUBLIC_KEY .env.prod -o .env.prod.age

# LLM Provider API Keys
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=gsk_your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
MISTRAL_API_KEY=your-key-here
GOOGLE_API_KEY=your-key-here

# Security
# Generate each with: python -c "import secrets; print(secrets.token_hex(32))"
# Both are REQUIRED in production — the app refuses to boot if either is unset
# or empty. JWT_SECRET_KEY signs auth tokens (and the signed guest cookies).
SECRET_KEY=generate-a-random-32-byte-hex
JWT_SECRET_KEY=generate-a-random-32-byte-hex
