---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => a.data.order - b.data.order,
);

const title = 'Devlog & Notes: Building My Poker Face';
const description =
  'Honest build notes from My Poker Face: how the AI opponents work, why the LLM stopped making the decisions, and what makes a poker table feel alive.';
---

<BaseLayout title={`${title} | My Poker Face`} description={description} path="/blog/">
  <section class="shell bloglist">
    <header class="bloglist__head">
      <p class="kicker">Devlog &amp; notes</p>
      <h1 class="bloglist__title">Building a poker game with living opponents</h1>
      <p class="bloglist__dek">
        Two threads, one project. The <strong>Devlog</strong> is how it's built;
        <strong>Inside the Table</strong> is what it's like to play. No press-release
        gloss. The wrong turns are kept in.
      </p>
    </header>

    <div class="filterbar" role="group" aria-label="Filter posts by track">
      <button class="filterbar__btn" data-filter="all" aria-pressed="true">All</button>
      <button class="filterbar__btn" data-filter="Devlog" aria-pressed="false">Devlog</button>
      <button class="filterbar__btn" data-filter="Inside the Table" aria-pressed="false">Inside the Table</button>
    </div>

    <ol class="bloglist__items">
      {
        posts.map((post) => (
          <li class="pcard" data-track={post.data.track}>
            <a class="pcard__link" href={`/blog/${post.id}/`}>
              {post.data.hero && (
                <div class="pcard__media">
                  <img src={post.data.hero} alt={post.data.heroAlt ?? post.data.title} loading="lazy" />
                </div>
              )}
              <div class="pcard__body">
                <p class="pcard__meta">
                  <span class={`tag tag--${post.data.track === 'Devlog' ? 'devlog' : 'table'}`}>
                    {post.data.track}
                  </span>
                  {post.data.draft && <span class="tag tag--draft">Draft</span>}
                </p>
                <h2 class="pcard__title">{post.data.title}</h2>
                <p class="pcard__excerpt">{post.data.excerpt}</p>
                <span class="pcard__more">Read →</span>
              </div>
            </a>
          </li>
        ))
      }
    </ol>

    <p class="bloglist__empty" hidden>No posts in that track yet.</p>
  </section>
</BaseLayout>

<script>
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filterbar__btn'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.pcard'));
  const empty = document.querySelector<HTMLElement>('.bloglist__empty');

  function apply(filter: string) {
    let shown = 0;
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.track === filter;
      card.hidden = !match;
      if (match) shown += 1;
    });
    buttons.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.filter === filter)));
    if (empty) empty.hidden = shown !== 0;
  }

  buttons.forEach((btn) => btn.addEventListener('click', () => apply(btn.dataset.filter ?? 'all')));
</script>

<style>
  .bloglist {
    max-width: 900px;
    padding-top: clamp(28px, 6vw, 64px);
    padding-bottom: clamp(48px, 8vw, 96px);
  }
  .bloglist__head { margin-bottom: clamp(28px, 5vw, 52px); }
  .bloglist__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2rem, 6vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 10px 0 16px;
  }
  .bloglist__dek {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.05rem, 2.4vw, 1.25rem);
    color: var(--text-dim);
    max-width: 60ch;
    margin: 0;
  }
  .bloglist__dek strong { font-style: normal; color: var(--gold-bright); font-weight: 600; }

  .filterbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 26px;
  }
  .filterbar__btn {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid var(--hair);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .filterbar__btn:hover { color: var(--text); border-color: rgba(212, 165, 116, 0.4); }
  .filterbar__btn[aria-pressed='true'] {
    color: var(--ink);
    background: var(--gold);
    border-color: var(--gold);
    font-weight: 600;
  }

  .bloglist__empty {
    color: var(--text-faint);
    font-family: var(--font-sans);
    padding: 24px 0;
  }

  .bloglist__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 22px;
  }

  .pcard {
    border: 1px solid var(--hair);
    border-radius: 16px;
    background: linear-gradient(180deg, var(--ink-2), var(--ink));
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .pcard:hover { border-color: rgba(212, 165, 116, 0.4); transform: translateY(-2px); }

  .pcard__link {
    display: grid;
    grid-template-columns: 240px 1fr;
    text-decoration: none;
    color: inherit;
  }
  .pcard__media { overflow: hidden; background: var(--ink-3); }
  .pcard__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .pcard__body { padding: clamp(18px, 3vw, 28px); }
  .pcard__meta { display: flex; gap: 8px; margin: 0 0 12px; }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--hair);
  }
  .tag--devlog { color: var(--gold-bright); border-color: rgba(212, 165, 116, 0.4); }
  .tag--table { color: #8fd0b6; border-color: rgba(143, 208, 182, 0.35); }
  .tag--draft { color: var(--text-faint); }

  .pcard__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    line-height: 1.15;
    margin: 0 0 10px;
  }
  .pcard__excerpt { color: var(--text-dim); margin: 0 0 14px; line-height: 1.55; }
  .pcard__more {
    font-family: var(--font-sans);
    font-size: 0.86rem;
    color: var(--gold-bright);
  }

  @media (max-width: 640px) {
    .pcard__link { grid-template-columns: 1fr; }
    .pcard__media { max-height: 200px; }
  }
</style>
