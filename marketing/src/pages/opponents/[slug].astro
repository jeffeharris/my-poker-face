---
import BaseLayout from '../../layouts/BaseLayout.astro';
import opponents from '../../data/opponents.json';

// One static page per circulating opponent. Adding the other 75 is automatic:
// the data comes from sync-opponents.mjs, this template renders each one.
export function getStaticPaths() {
  return opponents.map((o) => ({ params: { slug: o.slug }, props: { o } }));
}

const { o } = Astro.props;
const site = 'https://mypokerfacegame.com';
const url = `${site}/opponents/${o.slug}/`;
// "Play" CTAs target the app's entry point (the marketing site owns "/").
const playUrl = '/login';

const title = `Play Poker Against ${o.name} — AI Opponent | My Poker Face`;
const description =
  `${o.name} is a ${o.skill.toLowerCase()} who plays ${o.playStyle || 'a style all their own'}. ` +
  `Face them at the table free, in your browser. ${o.blurb}`.slice(0, 320);

const initials = o.name
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0])
  .join('')
  .toUpperCase();

const meters = [
  { label: 'Aggression', value: o.meters.aggression },
  { label: 'Looseness', value: o.meters.looseness },
  { label: 'Bluffing', value: o.meters.bluff },
  { label: 'Adaptability', value: o.meters.adaptability },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: 'My Poker Face',
    url: `${site}/`,
    applicationCategory: 'Game',
    operatingSystem: 'Web Browser',
    genre: ['Poker', 'Card Game'],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    character: {
      '@type': 'Person',
      name: o.name,
      description: o.identity,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Opponents', item: `${site}/opponents/` },
      { '@type': 'ListItem', position: 2, name: o.name, item: url },
    ],
  },
];
---

<BaseLayout title={title} description={description} path={`/opponents/${o.slug}/`} jsonLd={jsonLd}>
  <article class="shell op">
    <nav class="op__crumbs">
      <a href="/opponents/">← All opponents</a>
    </nav>

    <header class="op__hero">
      <div class="op__avatar">
        {
          o.avatar ? (
            <img src={o.avatar} alt={`${o.name}, an AI poker opponent in My Poker Face`} width="160" height="160" />
          ) : (
            <span class="op__mono" aria-hidden="true">{initials}</span>
          )
        }
      </div>
      <div class="op__heading">
        <p class="kicker">{o.skill} · plays {o.confidence || 'their own game'}</p>
        <h1 class="display op__name">Play poker against {o.name}</h1>
        <p class="op__identity">{o.identity}</p>
        <div class="op__cta">
          <a class="btn btn--gold" href={playUrl}>Take a seat against {o.firstName}</a>
        </div>
      </div>
    </header>

    <section class="op__grid">
      <div class="op__main">
        <h2 class="op__h2">At the table</h2>
        <p class="op__lead">{o.blurb}</p>
        <p class="op__style">
          Across a session, {o.firstName} plays {o.playStyle}. Like every opponent in My Poker
          Face, they read how you bet and bend their game toward your leaks — and the longer you
          sit, the sharper that read gets.
        </p>

        {
          o.verbalTics.length > 0 && (
            <>
              <h2 class="op__h2">What they’ll say to you</h2>
              <ul class="op__quotes">
                {o.verbalTics.map((q) => (
                  <li>“{q}”</li>
                ))}
              </ul>
            </>
          )
        }
      </div>

      <aside class="op__side">
        <div class="op__panel">
          <h3 class="op__panel-title">Playing profile</h3>
          <ul class="meters">
            {
              meters.map((m) => (
                <li class="meter">
                  <span class="meter__label">{m.label}</span>
                  <span class="meter__track">
                    <span class="meter__fill" style={`width:${Math.round(m.value * 100)}%`} />
                  </span>
                </li>
              ))
            }
          </ul>
          <p class="op__panel-note">
            Profiles evolve as you play — moods shift, and {o.firstName} starts to remember
            how you bet.
          </p>
        </div>
      </aside>
    </section>

    <section class="op__closer">
      <h2 class="display op__closer-title">The seat across from {o.firstName} is open.</h2>
      <a class="btn btn--gold" href={playUrl}>Play free — no download</a>
      <p class="op__closer-sub">
        Or <a href="/opponents/">meet the rest of the roster</a>.
      </p>
    </section>
  </article>

  <!-- Sticky CTA: appears after the hero scrolls away, hides again at the closer. -->
  <div class="stickycta" id="stickycta">
    <span class="stickycta__label">The seat across from {o.firstName} is open.</span>
    <a class="btn btn--gold" href={playUrl}>Take a seat</a>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var bar = document.getElementById('stickycta');
    var hero = document.querySelector('.op__hero');
    var closer = document.querySelector('.op__closer');
    if (!bar || !hero || !('IntersectionObserver' in window)) return;
    var pastHero = false;
    var atBottom = false;
    function update() {
      bar.classList.toggle('is-shown', pastHero && !atBottom);
    }
    new IntersectionObserver(
      function (e) {
        pastHero = !e[0].isIntersecting;
        update();
      },
      { rootMargin: '-20% 0px 0px 0px' }
    ).observe(hero);
    if (closer) {
      new IntersectionObserver(function (e) {
        atBottom = e[0].isIntersecting;
        update();
      }).observe(closer);
    }
  })();
</script>

<style>
  .op {
    padding-top: 28px;
    max-width: 1000px;
  }
  .op__crumbs a {
    text-decoration: none;
    color: var(--text-dim);
    font-size: 14px;
  }
  .op__crumbs a:hover {
    color: var(--gold);
  }
  .op__hero {
    display: flex;
    gap: clamp(20px, 4vw, 44px);
    align-items: center;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .op__avatar {
    flex: 0 0 auto;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 50% 30%, var(--felt), var(--felt-deep));
    border: 1px solid var(--hair);
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.8);
  }
  .op__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .op__mono {
    font-family: var(--font-serif);
    font-size: 58px;
    color: var(--gold-bright);
  }
  .op__name {
    font-size: clamp(32px, 5.5vw, 56px);
    margin: 10px 0 0;
  }
  .op__identity {
    margin: 14px 0 0;
    color: var(--text-dim);
    font-size: 18px;
    max-width: 52ch;
  }
  .op__cta {
    margin-top: 22px;
  }
  .op__grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: clamp(24px, 5vw, 56px);
    margin-top: 64px;
  }
  @media (max-width: 820px) {
    .op__grid {
      grid-template-columns: 1fr;
    }
  }
  .op__h2 {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 36px 0 12px;
  }
  .op__main .op__h2:first-child {
    margin-top: 0;
  }
  .op__lead {
    font-size: 20px;
    line-height: 1.55;
    margin: 0;
    color: var(--text);
  }
  .op__style,
  .op__desc {
    color: var(--text-dim);
    margin: 0;
  }
  .op__quotes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .op__quotes li {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text);
    padding-left: 16px;
    border-left: 2px solid var(--hair);
  }
  .op__panel {
    border: 1px solid var(--hair);
    border-radius: 16px;
    padding: 24px;
    background: radial-gradient(120% 140% at 0% 0%, rgba(212, 165, 116, 0.06), transparent 60%);
    position: sticky;
    top: 24px;
  }
  .op__panel-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 18px;
    margin: 0 0 18px;
  }
  .meters {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .meter__label {
    display: block;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }
  .meter__track {
    display: block;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    overflow: hidden;
  }
  .meter__fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--gold), var(--gold-bright));
  }
  .op__panel-note {
    margin: 18px 0 0;
    font-size: 13px;
    color: var(--text-faint);
    line-height: 1.5;
  }
  .op__closer {
    text-align: center;
    margin-top: 88px;
    padding: clamp(36px, 6vw, 72px) 0;
    border-top: 1px solid var(--hair-soft);
  }
  .op__closer-title {
    font-size: clamp(26px, 4vw, 42px);
    margin: 0 0 26px;
  }
  .op__closer-sub {
    margin: 20px 0 0;
    color: var(--text-faint);
    font-size: 14px;
  }
</style>
