# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Configuration (for Llama/Mixtral - very fast inference)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Configuration (for Claude models)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API Configuration (extremely cheap, near GPT-4 quality)
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Mistral API Configuration (European AI provider)
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Google Gemini API Configuration (free tier available)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# xAI API Configuration (for Grok models)
# Get a key at https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Pollinations.ai API Configuration (for cheap image generation)
# Get a key at https://pollinations.ai/ (optional, basic tier is free)
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Runware.ai API Configuration (for fast FLUX image generation)
# Get a key at https://runware.ai/
RUNWARE_API_KEY=your_runware_api_key_here

# =============================================================================
# Image Generation Configuration
# =============================================================================

# Image provider: "openai" (default), "pollinations" (cheap), or "runware" (fast)
# IMAGE_PROVIDER=runware

# Image model (provider-specific):
# - OpenAI: dall-e-2 (default), dall-e-3
# - Pollinations: flux (default), flux-realism, flux-anime, turbo, etc.
# - Runware: runware:101@1 (FLUX Schnell, default), runware:100@1 (FLUX Dev)
# IMAGE_MODEL=runware:101@1

# =============================================================================
# Model Overrides (Optional)
# =============================================================================
#
# Config priority: DB app_settings (admin dashboard) > env vars > hardcoded defaults
# DB settings are managed via the admin dashboard at runtime.
# Env vars here serve as fallbacks when no DB override exists.

# Default model for all LLM operations (any provider, not just OpenAI)
# DEFAULT_MODEL=gpt-5-nano

# Default LLM provider
# DEFAULT_PROVIDER=openai

# Fast model for quick operations like categorization, chat suggestions (defaults to DEFAULT_MODEL)
# FAST_MODEL=gpt-5-nano

# Assistant model for experiment design, analysis, theme generation
# ASSISTANT_MODEL=deepseek-chat
# ASSISTANT_PROVIDER=deepseek

# Port Configuration
BACKEND_PORT=5000
FRONTEND_PORT=5174
REDIS_PORT=6379
METABASE_PORT=3002
NGINX_PORT=80

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Initial Admin User
# The email of the user who should automatically get admin access on first login
# This user will be assigned to the 'admin' group which has 'can_access_admin_tools' permission
INITIAL_ADMIN_EMAIL=admin@example.com

# =============================================================================
# Google OAuth Authentication
# =============================================================================
# Enable "Sign in with Google" functionality
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URIs:
#    - Dev: http://localhost:5000/api/auth/google/callback
#    - Prod: https://mypokerfacegame.com/api/auth/google/callback
# 4. Copy Client ID and Secret below

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL for OAuth redirects (defaults to http://localhost:5173 for dev)
# Set to your production URL in production (e.g., https://mypokerfacegame.com)
# FRONTEND_URL=http://localhost:5173

# CORS Configuration
# Allowed origins for cross-origin requests
#
# Development (FLASK_ENV=development):
#   CORS_ORIGINS=* is allowed (without credentials, safe for local dev)
#
# Production (FLASK_ENV=production):
#   CORS_ORIGINS=* is NOT allowed (security requirement)
#   Must use comma-separated list of explicit origins with credentials
#   Example: CORS_ORIGINS=https://mypokerapp.com,https://www.mypokerapp.com
#
# Default for development:
CORS_ORIGINS=*

# Rate Limiting
# Redis URL for storing rate limit data
# For Docker Compose (recommended):
REDIS_URL=redis://redis:6379
# For local development without Docker:
# REDIS_URL=redis://localhost:6379

# Rate limits (format: "number per period" where period = second/minute/hour/day)
RATE_LIMIT_DEFAULT="200 per day, 50 per hour"
RATE_LIMIT_NEW_GAME="10 per hour"
RATE_LIMIT_GAME_ACTION="60 per minute"
RATE_LIMIT_CHAT_SUGGESTIONS="100 per hour"
RATE_LIMIT_GENERATE_PERSONALITY="15 per hour"

# =============================================================================
# LLM Prompt Capture (Playground Feature)
# =============================================================================

# Capture mode for prompts/responses (for debugging and replay)
# All captures go through the unified LLMClient with enricher callbacks that add
# full game state (hand, board, pot, stack, valid actions) when available.
# - "disabled" (default): No automatic capture
# - "all": Capture all LLM calls with full context
# - "all_except_decisions": Capture all except player_decision (useful to reduce volume)
LLM_PROMPT_CAPTURE=all

# Retention period for captured prompts in days (0 = keep forever)
LLM_PROMPT_RETENTION_DAYS=0

# =============================================================================
# Debug Features
# =============================================================================

# Enable debug UI panel (shows debug button on poker table)
ENABLE_DEBUG=false

# Enable AI debug mode (shows LLM model info when clicking AI player cards)
ENABLE_AI_DEBUG=false

# --- Cash-mode AI movement trace (debug) ---
# Logs why cash-mode AIs leave/arrive at a table (decision + the weighted
# leave-pressure breakdown) to the backend log and an append-only JSONL file.
# For diagnosing table churn / retention. OFF by default; opt-in.
# Master switch: 1 = on (traces tables with a human seated), 0 = off.
MOVEMENT_TRACE=0
# Also trace the autonomous world tables (every world tick) — very noisy,
# debug only: 1 = on, 0 = off.
MOVEMENT_TRACE_ALL=0
# JSONL output path. Append-only, NO rotation — clean up manually.
# MOVEMENT_TRACE_FILE=data/movement_trace.jsonl

# =============================================================================
# Coach Settings
# =============================================================================

# Source for action button highlighting: "coach" (default) or "gto"
# - "coach": Use coach LLM's recommendation for button highlighting
# - "gto": Use GTO (game theory optimal) calculation from DecisionAnalyzer
COACH_HIGHLIGHT_SOURCE=coach

# =============================================================================
# Sentry (session replay + bug-report widget + error monitoring)
# =============================================================================
# Create a project at https://sentry.io (free tier). Both DSNs below come from
# Project Settings → Client Keys (DSN) and are PUBLIC client keys (send-only) —
# safe to expose in the browser bundle. Leave empty to keep Sentry fully off
# (every Sentry code path becomes a no-op).
#
# Frontend: enables UX session replay + the floating "report a bug" launcher.
# Read at BUILD time (Vite inlines VITE_*). In prod it's baked into the image
# via the CI build-arg (repo secret VITE_SENTRY_DSN); for local Docker dev set
# it here and it flows through docker-compose.yml.
VITE_SENTRY_DSN=

# Backend: server-side error monitoring, tied to the same project so a session
# replay can be cross-referenced with the server error behind it.
SENTRY_DSN=
